generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                   @id @default(cuid())
  clerkId                String?                  @unique
  username               String                   @unique
  email                  String                   @unique
  displayName            String
  avatarUrl              String?
  oauthProvider          String?
  preferences            Json                     @default("{}")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  banned                 Boolean                  @default(false)
  skillLimit             Int?
  betterAuthId           String?                  @unique
  botActive              Boolean                  @default(true)
  botAvailable           Boolean                  @default(false)
  botProvisional         Boolean                  @default(false)
  botCompetitive         Boolean                  @default(false)
  botInTournament        Boolean                  @default(false)
  botLimit               Int?
  botModelId             String?                  @unique
  botModelType           String?
  botOwnerId             String?
  isBot                  Boolean                  @default(false)
  botEloResetAt          DateTime?
  botGamesPlayed         Int                      @default(0)
  creditsBpc             Int                      @default(0)
  creditsHpc             Int                      @default(0)
  creditsTc              Int                      @default(0)
  nameConfirmed          Boolean                  @default(false)
  lastActiveAt           DateTime?
  emailAchievements      Boolean                  @default(false)
  feedback               Feedback[]
  gameElo                GameElo[]
  gamesAsPlayer1         Game[]                   @relation("Player1Games")
  gamesAsPlayer2         Game[]                   @relation("Player2Games")
  gamesWon               Game[]                   @relation("WinnerGames")
  notifPreferences       NotificationPreference[]
  classification         PlayerClassification?
  tournamentParticipants TournamentParticipant[]
  eloHistory             UserEloHistory[]
  notifications          UserNotification[]
  pushSubscriptions      PushSubscription[]
  userRoles              UserRole[]
  seedBotConfigs         TournamentSeedBot[]
  templateSeedBotConfigs TournamentTemplateSeedBot[]

  @@map("users")
}

model Feedback {
  id             String           @id @default(cuid())
  appId          String           @default("xo-arena")
  userId         String?
  category       FeedbackCategory @default(OTHER)
  status         FeedbackStatus   @default(OPEN)
  message        String
  pageUrl        String
  screenshotData String?
  userAgent      String?
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   String?
  archivedAt     DateTime?
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  user           User?            @relation(fields: [userId], references: [id])
  replies        FeedbackReply[]

  @@index([appId])
  @@index([status])
  @@index([createdAt])
  @@index([readAt])
  @@index([archivedAt])
  @@map("feedback")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  adminId    String
  message    String
  createdAt  DateTime @default(now())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@map("feedback_replies")
}

model UserRole {
  id          String   @id @default(cuid())
  userId      String
  role        Role
  grantedById String
  grantedAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model UserEloHistory {
  id           String   @id @default(cuid())
  userId       String
  eloRating    Float
  delta        Float
  opponentType String
  outcome      String
  recordedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_elo_history")
}

/// Current ELO rating for a user in a specific game (replaces User.eloRating).
/// Note: game_elo table uses snake_case columns — @map required on all non-trivial fields.
model GameElo {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  gameId      String   @map("game_id")
  rating      Float    @default(1200)
  gamesPlayed Int      @default(0) @map("games_played")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@map("game_elo")
}

model Game {
  id                 String           @id @default(cuid())
  player1Id          String
  player2Id          String?
  winnerId           String?
  mode               GameMode
  aiImplementationId String?
  difficulty         Difficulty?
  outcome            Outcome
  totalMoves         Int
  durationMs         Int
  startedAt          DateTime
  endedAt            DateTime         @default(now())
  roomName           String?
  appId              String           @default("xo-arena")
  tournamentId       String?
  tournamentMatchId  String?
  isTournament       Boolean          @default(false)
  moveStream         Json?
  aiErrors           AIError[]
  player1            User             @relation("Player1Games", fields: [player1Id], references: [id])
  player2            User?            @relation("Player2Games", fields: [player2Id], references: [id])
  tournament         Tournament?      @relation(fields: [tournamentId], references: [id])
  tournamentMatch    TournamentMatch? @relation(fields: [tournamentMatchId], references: [id])
  winner             User?            @relation("WinnerGames", fields: [winnerId], references: [id])
  moves              Move[]

  @@index([outcome])
  @@index([aiImplementationId])
  @@index([difficulty])
  @@index([endedAt])
  @@index([player1Id])
  @@index([player2Id])
  @@index([tournamentId])
  @@map("games")
}

model Move {
  id            String     @id @default(cuid())
  gameId        String
  moveNumber    Int
  player        MovePlayer
  boardState    Json
  cellIndex     Int
  computationMs Int?
  timestamp     DateTime   @default(now())
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("moves")
}

model AIError {
  id               String   @id @default(cuid())
  gameId           String
  moveNumber       Int
  implementationId String
  errorType        String
  message          String
  stackTrace       String?
  timestamp        DateTime @default(now())
  game             Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([implementationId])
  @@map("ai_errors")
}

model BotSkill {
  id             String              @id(map: "ml_models_pkey") @default(cuid())
  name           String
  description    String?
  algorithm      String
  weights        Json                @default("{}")
  config         Json
  status         BotSkillStatus      @default(IDLE)
  totalEpisodes  Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  featured       Boolean             @default(false)
  createdBy      String?
  maxEpisodes    Int                 @default(100000)
  botId          String?             @map("bot_id")
  gameId         String              @default("xo") @map("game_id")
  benchmarks     MLBenchmarkResult[]
  checkpoints    MLCheckpoint[]
  eloHistory     MLEloHistory[]
  playerProfiles MLPlayerProfile[]
  sessions       TrainingSession[]

  @@unique([botId, gameId], where: raw("(bot_id IS NOT NULL)"))
  @@map("bot_skills")
}

model MLPlayerProfile {
  id                 String   @id @default(uuid())
  modelId            String
  userId             String
  gamesRecorded      Int      @default(0)
  movePatterns       Json     @default("{}")
  openingPreferences Json     @default("{}")
  tendencies         Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  model              BotSkill @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, userId])
  @@map("ml_player_profiles")
}

model TrainingSession {
  id          String            @id @default(cuid())
  modelId     String
  mode        TrainingMode
  iterations  Int
  status      SessionStatus     @default(PENDING)
  config      Json
  summary     Json?
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  episodes    TrainingEpisode[]
  model       BotSkill          @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("training_sessions")
}

model TrainingEpisode {
  id         String          @id @default(cuid())
  sessionId  String
  episodeNum Int
  outcome    EpisodeOutcome
  totalMoves Int
  avgQDelta  Float
  epsilon    Float
  durationMs Int
  session    TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("training_episodes")
}

model MLCheckpoint {
  id         String   @id @default(cuid())
  modelId    String
  episodeNum Int
  weights    Json
  epsilon    Float
  createdAt  DateTime @default(now())
  model      BotSkill @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_checkpoints")
}

model MLBenchmarkResult {
  id       String   @id @default(cuid())
  modelId  String
  runAt    DateTime @default(now())
  vsRandom Json
  vsEasy   Json
  vsMedium Json
  vsHard   Json
  summary  Json
  vsTough  Json?
  model    BotSkill @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_benchmark_results")
}

model MLEloHistory {
  id           String         @id @default(cuid())
  modelId      String
  eloRating    Float
  delta        Float
  opponentId   String?
  opponentType String
  outcome      EpisodeOutcome
  recordedAt   DateTime       @default(now())
  model        BotSkill       @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_elo_history")
}

model RuleSet {
  id           String   @id @default(cuid())
  name         String
  description  String?
  rules        Json     @default("[]")
  sourceModels Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("rule_sets")
}

model MLTournament {
  id           String    @id @default(cuid())
  status       String    @default("PENDING")
  modelIds     Json
  gamesPerPair Int       @default(50)
  results      Json      @default("{}")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("ml_tournaments")
}

model Log {
  id        String   @id @default(cuid())
  level     String
  source    String
  message   String
  userId    String?
  sessionId String?
  roomId    String?
  meta      Json?
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([level])
  @@index([source])
  @@map("logs")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model BaUser {
  id            String      @id
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  role          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now())
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  accounts      BaAccount[]
  sessions      BaSession[]

  @@map("ba_users")
}

model BaSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  userId    String
  user      BaUser   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token])
  @@map("ba_sessions")
}

model BaAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
  user                  BaUser    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("ba_accounts")
}

model Jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())

  @@map("ba_jwks")
}

model BaVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("ba_verifications")
}

model UserNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  payload     Json
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  emailedAt   DateTime?
  readAt      DateTime?
  expiresAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deliveredAt])
  @@map("user_notifications")
}

model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String
  eventType String
  inApp     Boolean @default(true)
  email     Boolean @default(false)
  sms       Boolean @default(false)
  push      Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model ScheduledJob {
  id          String             @id @default(cuid())
  type        String
  payload     Json
  runAt       DateTime
  status      ScheduledJobStatus @default(PENDING)
  attempts    Int                @default(0)
  maxAttempts Int                @default(3)
  lastError   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, runAt])
  @@map("scheduled_jobs")
}

model Tournament {
  id                      String                  @id @default(cuid())
  name                    String
  description             String?
  game                    String
  mode                    TournamentMode
  format                  TournamentFormat
  bracketType             BracketType
  status                  TournamentStatus        @default(DRAFT)
  minParticipants         Int                     @default(2)
  maxParticipants         Int?
  bestOfN                 Int                     @default(3)
  botMinGamesPlayed       Int?
  allowNonCompetitiveBots Boolean                 @default(false)
  allowSpectators         Boolean                 @default(true)
  startTime               DateTime?
  endTime                 DateTime?
  registrationOpenAt      DateTime?
  registrationCloseAt     DateTime?
  noticePeriodMinutes     Int?
  durationMinutes         Int?
  // Phase 3.7a — recurrence config moves to TournamentTemplate. These fields
  // remain on the Tournament row for one migration step; after data-backfill
  // we'll drop them. templateId set on occurrences spawned from a template.
  isRecurring             Boolean                 @default(false)
  autoOptOutAfterMissed   Int?
  templateId              String?
  template                TournamentTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdById             String
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  paceMs                  Int?                    @map("pace_ms")
  recurrenceInterval      RecurrenceInterval?
  recurrenceEndDate       DateTime?
  // Admin switch that halts generation of new occurrences without cancelling
  // the template. Running occurrences are unaffected. Flip back to false to
  // resume the schedule — the next sweep picks up where the interval left off.
  recurrencePaused        Boolean                 @default(false)
  startMode               TournamentStartMode     @default(AUTO)
  // True when created by an automated test suite; hidden from the public
  // /tournaments page (filtered at the API layer) and exposed behind an
  // admin toggle. Never set by end users.
  isTest                  Boolean                 @default(false)
  games                   Game[]
  participants            TournamentParticipant[]
  rounds                  TournamentRound[]
  seedBots                TournamentSeedBot[]

  @@index([status])
  @@index([game])
  @@index([createdById])
  @@index([templateId])
  @@map("tournaments")
}

/// Phase 3.7a — holds recurrence *configuration* only. Never itself runs.
/// Each recurring series is one TournamentTemplate + N spawned Tournament
/// occurrences (each with `templateId` pointing back here). Subscribers
/// attach to the template; seed bots attach to the template; running state
/// (bracket, matches, results) lives exclusively on the occurrences.
model TournamentTemplate {
  id                      String                            @id @default(cuid())
  name                    String
  description             String?
  game                    String
  mode                    TournamentMode
  format                  TournamentFormat
  bracketType             BracketType
  minParticipants         Int                               @default(2)
  maxParticipants         Int?
  bestOfN                 Int                               @default(3)
  botMinGamesPlayed       Int?
  allowNonCompetitiveBots Boolean                           @default(false)
  allowSpectators         Boolean                           @default(true)
  noticePeriodMinutes     Int?
  durationMinutes         Int?
  paceMs                  Int?                              @map("pace_ms")
  startMode               TournamentStartMode               @default(AUTO)
  // Recurrence config
  recurrenceInterval      RecurrenceInterval
  /// First (or next) occurrence start — scheduler reads this to decide when
  /// to spawn the next Tournament row.
  recurrenceStart         DateTime
  recurrenceEndDate       DateTime?
  /// Registration window for the NEXT occurrence. Both advance by the
  /// recurrence interval each time the scheduler spawns an occurrence, so
  /// they always describe the upcoming occurrence. Null fields fall back
  /// to defaults at spawn time (open = now, close = startTime).
  registrationOpenAt      DateTime?
  registrationCloseAt     DateTime?
  /// Halts generation of new occurrences without cancelling the template.
  /// Running occurrences (already spawned) are unaffected.
  paused                  Boolean                           @default(false)
  autoOptOutAfterMissed   Int?
  createdById             String
  createdAt               DateTime                          @default(now())
  updatedAt               DateTime                          @updatedAt
  /// True when created by an automated test suite.
  isTest                  Boolean                           @default(false)
  tournaments             Tournament[]
  seedBots                TournamentTemplateSeedBot[]
  subscriptions           RecurringTournamentRegistration[]

  @@index([game])
  @@index([createdById])
  @@index([paused, recurrenceStart])
  @@map("tournament_templates")
}

model TournamentParticipant {
  id                String            @id @default(cuid())
  tournamentId      String
  userId            String
  seedPosition      Int?
  eloAtRegistration Float?
  status            ParticipantStatus @default(REGISTERED)
  resultNotifPref   ResultNotifPref   @default(AS_PLAYED)
  finalPosition     Int?
  /// Normalised rank: 0.0 = winner (best), 1.0 = last place (worst). Null until tournament ends.
  finalPositionPct  Float?
  registeredAt      DateTime          @default(now())
  points            Int               @default(0)
  registrationMode  RegistrationMode  @default(SINGLE)
  tournament        Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@map("tournament_participants")
}

model TournamentRound {
  id           String            @id @default(cuid())
  tournamentId String
  roundNumber  Int
  status       RoundStatus       @default(PENDING)
  createdAt    DateTime          @default(now())
  matches      TournamentMatch[]
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
  @@map("tournament_rounds")
}

model TournamentMatch {
  id             String          @id @default(cuid())
  tournamentId   String
  roundId        String
  participant1Id String?
  participant2Id String?
  winnerId       String?
  status         MatchStatus     @default(PENDING)
  drawResolution String?
  p1Wins         Int             @default(0)
  p2Wins         Int             @default(0)
  drawGames      Int             @default(0)
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  games          Game[]
  round          TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([roundId])
  @@map("tournament_matches")
}

model PlayerClassification {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  tier                 ClassificationTier      @default(RECRUIT)
  merits               Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  demotionOptOutUsedAt DateTime?
  history              ClassificationHistory[]
  meritTx              MeritTransaction[]
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("player_classifications")
}

model MeritTransaction {
  id               String               @id @default(cuid())
  classificationId String
  tournamentId     String?
  delta            Int
  reason           String
  createdAt        DateTime             @default(now())
  classification   PlayerClassification @relation(fields: [classificationId], references: [id], onDelete: Cascade)

  @@index([classificationId])
  @@index([tournamentId])
  @@map("merit_transactions")
}

model ClassificationHistory {
  id               String               @id @default(cuid())
  classificationId String
  fromTier         ClassificationTier?
  toTier           ClassificationTier
  reason           String
  tournamentId     String?
  createdAt        DateTime             @default(now())
  classification   PlayerClassification @relation(fields: [classificationId], references: [id], onDelete: Cascade)

  @@index([classificationId])
  @@map("classification_history")
}

model MeritThreshold {
  id      String @id @default(cuid())
  bandMin Int
  bandMax Int?
  pos1    Int
  pos2    Int
  pos3    Int
  pos4    Int

  @@map("merit_thresholds")
}

model RecurringTournamentRegistration {
  id          String              @id @default(cuid())
  templateId  String
  userId      String
  missedCount Int                 @default(0)
  optedOutAt  DateTime?
  createdAt   DateTime            @default(now())
  /// Phase 3.7a: FK now targets TournamentTemplate (was Tournament with
  /// isRecurring:true). Cascade so deleting a template cleans up subs.
  template    TournamentTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId])
  @@index([templateId])
  @@index([userId])
  @@map("recurring_tournament_registrations")
}

model TournamentSeedBot {
  id           String     @id @default(cuid())
  tournamentId String
  userId       String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@map("tournament_seed_bots")
}

/// Phase 3.7a — seed bots attached to a recurring-tournament *template*.
/// Every spawned occurrence inherits these; the `TournamentSeedBot` table
/// above stays for per-occurrence overrides on one-shot tournaments.
model TournamentTemplateSeedBot {
  id         String             @id @default(cuid())
  templateId String
  userId     String
  template   TournamentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id])
  createdAt  DateTime           @default(now())

  @@unique([templateId, userId])
  @@index([templateId])
  @@map("tournament_template_seed_bots")
}

model Table {
  id                String      @id @default(cuid())
  gameId            String
  status            TableStatus @default(FORMING)
  createdById       String
  minPlayers        Int
  maxPlayers        Int
  isPrivate         Boolean     @default(false)
  chatEnabled       Boolean     @default(false)
  isTournament      Boolean     @default(false)
  /// Array of seat objects: { userId: string|null, status: "occupied" | "empty" }.
  /// Length always equals maxPlayers; empty seats have userId: null.
  seats             Json
  /// Full game state blob — replaces the in-memory Room's board/turn/scores.
  /// Shape: { board, currentTurn, scores, round, winner, winLine, marks, botMark, moves }
  /// Updated on every move; game-defined but platform reads status fields for
  /// lifecycle decisions (e.g., marking Table COMPLETED on winner).
  previewState      Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  /// Phase 3.4 — tournament context (null for free-play tables).
  tournamentMatchId String?
  tournamentId      String?
  bestOfN           Int?
  /// Phase 3.4 — bot context (null for PvP tables).
  isHvb             Boolean     @default(false)
  botUserId         String?
  botSkillId        String?
  slug              String?     @unique
  displayName       String?

  @@index([status])
  @@index([gameId])
  @@index([createdById])
  @@index([isTournament])
  @@index([tournamentMatchId])
  @@index([botUserId])
  @@map("tables")
}

enum ScheduledJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum Role {
  ADMIN
  BOT_ADMIN
  TOURNAMENT_ADMIN
  SUPPORT
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  OTHER
