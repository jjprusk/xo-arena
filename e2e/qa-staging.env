# qa-staging.env — overlay for running the QA suite against staging.
#
# Usage:
#   cd e2e
#   set -a; . ./qa.env; . ./qa-staging.env; set +a
#   BASE_URL=https://xo-frontend-staging.fly.dev \
#   LANDING_URL=https://xo-landing-staging.fly.dev \
#   BACKEND_URL=https://xo-backend-staging.fly.dev \
#   TOURNAMENT_URL=https://xo-tournament-staging.fly.dev \
#     npx playwright test --project=chromium
#
# Why an overlay: qa.env holds credentials for the local dev database. The
# staging DB never sees dev seed rows, and Better Auth on staging enforces
# an 8-char minimum password (the dev TEST_USER_PASSWORD is 7 chars and
# predates that rule). Rather than mutate qa.env and force every dev env
# to update, we reroute TEST_USER_* → TEST_USER2_* on staging, whose
# 9-char password meets the policy. TEST_USER2_* are signed up on staging
# with the same values used locally, so no new secrets are introduced.
#
# Staging seed was performed once via:
#   1. POST /api/auth/sign-up/email for both accounts
#   2. fly proxy 15432:5432 -a xo-db-staging
#   3. psql: UPDATE ba_users SET "emailVerified"=true WHERE email IN (...)
#   4. psql: UPDATE ba_users SET role='admin' WHERE email=<admin>
#
# If staging's DB is wiped (prod-style bringup or local reset), repeat.

# PvP / spectator tests need TWO distinct user accounts. TEST_USER on
# staging maps to a purpose-signed-up qa-host-staging account (8+ chars,
# emailVerified). TEST_USER2 stays at qa-user-2@dev.local.
export TEST_USER_EMAIL="qa-host-staging@dev.local"
export TEST_USER_PASSWORD="$TEST_USER2_PASSWORD"
