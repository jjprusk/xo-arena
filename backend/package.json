{
  "name": "@xo-arena/backend",
  "version": "1.2.0-alpha-1.05",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ignore src/generated --watch ../packages/db/prisma/schema.prisma --ext js,mjs,ts,prisma --exec 'npx prisma generate --schema=../packages/db/prisma/schema.prisma && node --experimental-transform-types src/index.js'",
    "start": "npx prisma migrate deploy --schema=../packages/db/prisma/schema.prisma && node --experimental-transform-types src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev --schema=../packages/db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=../packages/db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=../packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../packages/db/prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "um": "node --experimental-transform-types --no-warnings src/cli/um.js"
  },
  "bin": {
    "um": "./src/cli/um.js"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@xo-arena/ai": "file:../packages/ai",
    "@xo-arena/db": "file:../packages/db",
    "better-auth": "^1.5.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.4.2",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.0.0",
    "resend": "^6.9.4",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0",
    "vitest": "^3.0.5"
  }
}
