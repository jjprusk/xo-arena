// This is your Prisma schema file.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  clerkId       String?  @unique
  betterAuthId  String?  @unique
  username      String   @unique
  email         String   @unique
  displayName   String
  avatarUrl     String?
  oauthProvider String? // "google" | "apple" | "email"
  preferences   Json     @default("{}")
  eloRating     Float    @default(1200)
  banned        Boolean  @default(false)
  mlModelLimit  Int?     // null = use system default (ml.maxModelsPerUser)

  // Bot fields — null/false on all regular users
  isBot           Boolean  @default(false)
  botModelType    String?  // 'minimax' | 'mcts' | 'rule_based' | 'ml'
  botModelId      String?  @unique // FK to MLModel.id or built-in ID; unique = one bot per model
  botOwnerId      String?  // FK to User.id; null for built-in bots
  botActive       Boolean  @default(true)   // false = hidden from picker (soft disable)
  botCompetitive  Boolean  @default(false)  // true = eligible for leaderboard + tournaments
  botAvailable    Boolean  @default(false)  // true = available for tournament scheduling
  botInTournament Boolean  @default(false)  // true = in active tournament; blocks training
  botCalibrating  Boolean  @default(false)  // true = calibration games in progress
  botLimit        Int?     // per-user override for max bots; null = system default

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gamesAsPlayer1 Game[]           @relation("Player1Games")
  gamesAsPlayer2 Game[]           @relation("Player2Games")
  gamesWon       Game[]           @relation("WinnerGames")
  eloHistory     UserEloHistory[]
  userRoles      UserRole[]

  @@map("users")
}

enum Role {
  ADMIN            // full platform access — implicitly satisfies any role check
  BOT_ADMIN        // manage all bots, set per-user bot limits
  TOURNAMENT_ADMIN // future
}

model UserRole {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role
  grantedById String   // User.id of who assigned the role
  grantedAt   DateTime @default(now())

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model UserEloHistory {
  id           String   @id @default(cuid())
  userId       String
  eloRating    Float
  delta        Float
  opponentType String   // 'ai_novice' | 'ai_intermediate' | 'ai_advanced' | 'ai_master' | 'human'
  outcome      String   // 'win' | 'loss' | 'draw'
  recordedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_elo_history")
}

model Game {
  id               String    @id @default(cuid())
  player1Id        String
  player2Id        String?   // null for AI games
  winnerId         String?   // null for draw
  mode             GameMode
  aiImplementationId String? // if PvAI
  difficulty       Difficulty?
  outcome          Outcome
  totalMoves       Int
  durationMs       Int
  startedAt        DateTime
  endedAt          DateTime  @default(now())
  roomName         String?   // mountain name for PvP

  player1  User   @relation("Player1Games", fields: [player1Id], references: [id])
  player2  User?  @relation("Player2Games", fields: [player2Id], references: [id])
  winner   User?  @relation("WinnerGames", fields: [winnerId], references: [id])
  moves    Move[]
  aiErrors AIError[]

  @@index([outcome])
  @@index([aiImplementationId])
  @@index([difficulty])
  @@index([endedAt])
  @@index([player1Id])
  @@index([player2Id])
  @@map("games")
}

model Move {
  id            String   @id @default(cuid())
  gameId        String
  moveNumber    Int
  player        MovePlayer
  boardState    Json     // 9-element array snapshot before the move
  cellIndex     Int
  computationMs Int?     // AI moves only
  timestamp     DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("moves")
}

model AIError {
  id               String   @id @default(cuid())
  gameId           String
  moveNumber       Int
  implementationId String
  errorType        String
  message          String
  stackTrace       String?
  timestamp        DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([implementationId])
  @@map("ai_errors")
}

enum GameMode {
  PVP
  PVAI   // quick game vs built-in difficulty (no named bot)
  PVBOT  // challenge a named bot
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Outcome {
  PLAYER1_WIN
  PLAYER2_WIN
  AI_WIN
  DRAW
}

enum MovePlayer {
  HUMAN
  AI
}

// ─── Machine Learning ────────────────────────────────────────────────────────

model MLModel {
  id            String        @id @default(cuid())
  name          String
  description   String?
  algorithm     MLAlgorithm   @default(Q_LEARNING)
  qtable        Json          @default("{}")
  config        Json
  status        MLModelStatus @default(IDLE)
  featured      Boolean       @default(false)
  createdBy     String?       // Clerk user ID of the model's creator
  totalEpisodes Int           @default(0)
  maxEpisodes   Int           @default(100000) // lifetime training cap; 0 = unlimited
  eloRating     Float         @default(1000)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions       TrainingSession[]
  checkpoints    MLCheckpoint[]
  benchmarks     MLBenchmarkResult[]
  eloHistory     MLEloHistory[]
  playerProfiles MLPlayerProfile[]

  @@map("ml_models")
}

model MLPlayerProfile {
  id                 String   @id @default(uuid())
  modelId            String
  userId             String
  gamesRecorded      Int      @default(0)
  movePatterns       Json     @default("{}")   // { stateKey: { cellIndex: count } }
  openingPreferences Json     @default("{}")   // { cellIndex: count } (first moves)
  tendencies         Json     @default("{}")   // { centerRate, cornerRate, blockingRate }
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, userId])
  @@map("ml_player_profiles")
}

model TrainingSession {
  id          String        @id @default(cuid())
  modelId     String
  mode        TrainingMode
  iterations  Int
  status      SessionStatus @default(PENDING)
  config      Json
  summary     Json?
  startedAt   DateTime      @default(now())
  completedAt DateTime?

  model    MLModel           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  episodes TrainingEpisode[]

  @@index([modelId])
  @@map("training_sessions")
}

model TrainingEpisode {
  id         String         @id @default(cuid())
  sessionId  String
  episodeNum Int
  outcome    EpisodeOutcome
  totalMoves Int
  avgQDelta  Float
  epsilon    Float
  durationMs Int

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("training_episodes")
}

model MLCheckpoint {
  id         String   @id @default(cuid())
  modelId    String
  episodeNum Int
  qtable     Json
  epsilon    Float
  eloRating  Float
  createdAt  DateTime @default(now())

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_checkpoints")
}

model MLBenchmarkResult {
  id       String   @id @default(cuid())
  modelId  String
  runAt    DateTime @default(now())
  vsRandom Json
  vsEasy   Json
  vsMedium Json
  vsTough  Json
  vsHard   Json
  summary  Json

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_benchmark_results")
}

model MLEloHistory {
  id           String         @id @default(cuid())
  modelId      String
  eloRating    Float
  delta        Float
  opponentId   String?
  opponentType String
  outcome      EpisodeOutcome
  recordedAt   DateTime       @default(now())

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_elo_history")
}

model RuleSet {
  id           String   @id @default(cuid())
  name         String
  description  String?
  rules        Json     @default("[]")
  sourceModels Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("rule_sets")
}

model MLTournament {
  id           String    @id @default(cuid())
  status       String    @default("PENDING")
  modelIds     Json
  gamesPerPair Int       @default(50)
  results      Json      @default("{}")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("ml_tournaments")
}

model Log {
  id        String   @id @default(cuid())
  level     String   // DEBUG | INFO | WARN | ERROR | FATAL
  source    String   // frontend | api | realtime | ai
  message   String
  userId    String?
  sessionId String?
  roomId    String?
  meta      Json?
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([level])
  @@index([source])
  @@map("logs")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

enum MLAlgorithm {
  Q_LEARNING
  SARSA
  MONTE_CARLO
  POLICY_GRADIENT
  DQN
  ALPHA_ZERO
}

enum MLModelStatus {
  IDLE
  TRAINING
}

enum TrainingMode {
  SELF_PLAY
  VS_MINIMAX
  VS_HUMAN
}

enum SessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EpisodeOutcome {
  WIN
  LOSS
  DRAW
}

// ─── Better Auth tables ───────────────────────────────────────────────────────

model BaUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime
  updatedAt     DateTime

  sessions  BaSession[]
  accounts  BaAccount[]

  @@map("ba_users")
}

model BaSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      BaUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ba_sessions")
}

model BaAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  BaUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ba_accounts")
}

model Jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime

  @@map("ba_jwks")
}

model BaVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("ba_verifications")
}
