generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  clerkId         String?          @unique
  username        String           @unique
  email           String           @unique
  displayName     String
  avatarUrl       String?
  oauthProvider   String?
  preferences     Json             @default("{}")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  eloRating       Float            @default(1200)
  banned          Boolean          @default(false)
  mlModelLimit    Int?
  betterAuthId    String?          @unique
  botActive       Boolean          @default(true)
  botAvailable    Boolean          @default(false)
  botProvisional  Boolean          @default(false)
  botCompetitive  Boolean          @default(false)
  botInTournament Boolean          @default(false)
  botLimit        Int?
  botModelId      String?          @unique
  botModelType    String?
  botOwnerId      String?
  isBot           Boolean          @default(false)
  botEloResetAt   DateTime?
  botGamesPlayed  Int              @default(0)
  creditsHpc      Int              @default(0)
  creditsBpc      Int              @default(0)
  creditsTc       Int              @default(0)
  gamesAsPlayer1  Game[]           @relation("Player1Games")
  gamesAsPlayer2  Game[]           @relation("Player2Games")
  gamesWon        Game[]           @relation("WinnerGames")
  eloHistory      UserEloHistory[]
  userRoles       UserRole[]
  notifications   UserNotification[]

  @@map("users")
}

model UserRole {
  id          String   @id @default(cuid())
  userId      String
  role        Role
  grantedById String
  grantedAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model UserEloHistory {
  id           String   @id @default(cuid())
  userId       String
  eloRating    Float
  delta        Float
  opponentType String
  outcome      String
  recordedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_elo_history")
}

model Game {
  id                 String      @id @default(cuid())
  player1Id          String
  player2Id          String?
  winnerId           String?
  mode               GameMode
  aiImplementationId String?
  difficulty         Difficulty?
  outcome            Outcome
  totalMoves         Int
  durationMs         Int
  startedAt          DateTime
  endedAt            DateTime    @default(now())
  roomName           String?
  aiErrors           AIError[]
  player1            User        @relation("Player1Games", fields: [player1Id], references: [id])
  player2            User?       @relation("Player2Games", fields: [player2Id], references: [id])
  winner             User?       @relation("WinnerGames", fields: [winnerId], references: [id])
  moves              Move[]

  @@index([outcome])
  @@index([aiImplementationId])
  @@index([difficulty])
  @@index([endedAt])
  @@index([player1Id])
  @@index([player2Id])
  @@map("games")
}

model Move {
  id            String     @id @default(cuid())
  gameId        String
  moveNumber    Int
  player        MovePlayer
  boardState    Json
  cellIndex     Int
  computationMs Int?
  timestamp     DateTime   @default(now())
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("moves")
}

model AIError {
  id               String   @id @default(cuid())
  gameId           String
  moveNumber       Int
  implementationId String
  errorType        String
  message          String
  stackTrace       String?
  timestamp        DateTime @default(now())
  game             Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([implementationId])
  @@map("ai_errors")
}

model MLModel {
  id             String              @id @default(cuid())
  name           String
  description    String?
  algorithm      MLAlgorithm         @default(Q_LEARNING)
  qtable         Json                @default("{}")
  config         Json
  status         MLModelStatus       @default(IDLE)
  totalEpisodes  Int                 @default(0)
  eloRating      Float               @default(1000)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  featured       Boolean             @default(false)
  createdBy      String?
  maxEpisodes    Int                 @default(100000)
  benchmarks     MLBenchmarkResult[]
  checkpoints    MLCheckpoint[]
  eloHistory     MLEloHistory[]
  playerProfiles MLPlayerProfile[]
  sessions       TrainingSession[]

  @@map("ml_models")
}

model MLPlayerProfile {
  id                 String   @id @default(uuid())
  modelId            String
  userId             String
  gamesRecorded      Int      @default(0)
  movePatterns       Json     @default("{}")
  openingPreferences Json     @default("{}")
  tendencies         Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  model              MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, userId])
  @@map("ml_player_profiles")
}

model TrainingSession {
  id          String            @id @default(cuid())
  modelId     String
  mode        TrainingMode
  iterations  Int
  status      SessionStatus     @default(PENDING)
  config      Json
  summary     Json?
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  episodes    TrainingEpisode[]
  model       MLModel           @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("training_sessions")
}

model TrainingEpisode {
  id         String          @id @default(cuid())
  sessionId  String
  episodeNum Int
  outcome    EpisodeOutcome
  totalMoves Int
  avgQDelta  Float
  epsilon    Float
  durationMs Int
  session    TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("training_episodes")
}

model MLCheckpoint {
  id         String   @id @default(cuid())
  modelId    String
  episodeNum Int
  qtable     Json
  epsilon    Float
  eloRating  Float
  createdAt  DateTime @default(now())
  model      MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_checkpoints")
}

model MLBenchmarkResult {
  id       String   @id @default(cuid())
  modelId  String
  runAt    DateTime @default(now())
  vsRandom Json
  vsEasy   Json
  vsMedium Json
  vsHard   Json
  summary  Json
  vsTough  Json?
  model    MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_benchmark_results")
}

model MLEloHistory {
  id           String         @id @default(cuid())
  modelId      String
  eloRating    Float
  delta        Float
  opponentId   String?
  opponentType String
  outcome      EpisodeOutcome
  recordedAt   DateTime       @default(now())
  model        MLModel        @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_elo_history")
}

model RuleSet {
  id           String   @id @default(cuid())
  name         String
  description  String?
  rules        Json     @default("[]")
  sourceModels Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("rule_sets")
}

model MLTournament {
  id           String    @id @default(cuid())
  status       String    @default("PENDING")
  modelIds     Json
  gamesPerPair Int       @default(50)
  results      Json      @default("{}")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("ml_tournaments")
}

model Log {
  id        String   @id @default(cuid())
  level     String
  source    String
  message   String
  userId    String?
  sessionId String?
  roomId    String?
  meta      Json?
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([level])
  @@index([source])
  @@map("logs")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model BaUser {
  id            String      @id
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  role          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now())
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  accounts      BaAccount[]
  sessions      BaSession[]

  @@map("ba_users")
}

model BaSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  userId    String
  user      BaUser   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token])
  @@map("ba_sessions")
}

model BaAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
  user                  BaUser    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("ba_accounts")
}

model Jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())

  @@map("ba_jwks")
}

model BaVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("ba_verifications")
}

model UserNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  payload     Json
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deliveredAt])
  @@map("user_notifications")
}

enum Role {
  ADMIN
  BOT_ADMIN
  TOURNAMENT_ADMIN
}

enum GameMode {
  PVP
  PVAI
  PVBOT
  BOTVBOT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  NOVICE
  INTERMEDIATE
  ADVANCED
  MASTER
}

enum Outcome {
  PLAYER1_WIN
  PLAYER2_WIN
  AI_WIN
  DRAW
}

enum MovePlayer {
  HUMAN
  AI
}

enum MLAlgorithm {
  Q_LEARNING
  SARSA
  MONTE_CARLO
  POLICY_GRADIENT
  DQN
  ALPHA_ZERO
}

enum MLModelStatus {
  IDLE
  TRAINING
}

enum TrainingMode {
  SELF_PLAY
  VS_MINIMAX
  VS_HUMAN
}

enum SessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EpisodeOutcome {
  WIN
  LOSS
  DRAW
}
