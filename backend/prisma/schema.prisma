// This is your Prisma schema file.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  email        String   @unique
  displayName  String
  avatarUrl    String?
  oauthProvider String? // "google" | "apple" | "email"
  preferences  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gamesAsPlayer1 Game[] @relation("Player1Games")
  gamesAsPlayer2 Game[] @relation("Player2Games")
  gamesWon       Game[] @relation("WinnerGames")

  @@map("users")
}

model Game {
  id               String    @id @default(cuid())
  player1Id        String
  player2Id        String?   // null for AI games
  winnerId         String?   // null for draw
  mode             GameMode
  aiImplementationId String? // if PvAI
  difficulty       Difficulty?
  outcome          Outcome
  totalMoves       Int
  durationMs       Int
  startedAt        DateTime
  endedAt          DateTime  @default(now())
  roomName         String?   // mountain name for PvP

  player1  User   @relation("Player1Games", fields: [player1Id], references: [id])
  player2  User?  @relation("Player2Games", fields: [player2Id], references: [id])
  winner   User?  @relation("WinnerGames", fields: [winnerId], references: [id])
  moves    Move[]
  aiErrors AIError[]

  @@index([outcome])
  @@index([aiImplementationId])
  @@index([difficulty])
  @@index([endedAt])
  @@index([player1Id])
  @@index([player2Id])
  @@map("games")
}

model Move {
  id            String   @id @default(cuid())
  gameId        String
  moveNumber    Int
  player        MovePlayer
  boardState    Json     // 9-element array snapshot before the move
  cellIndex     Int
  computationMs Int?     // AI moves only
  timestamp     DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("moves")
}

model AIError {
  id               String   @id @default(cuid())
  gameId           String
  moveNumber       Int
  implementationId String
  errorType        String
  message          String
  stackTrace       String?
  timestamp        DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([implementationId])
  @@map("ai_errors")
}

enum GameMode {
  PVP
  PVAI
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Outcome {
  PLAYER1_WIN
  PLAYER2_WIN
  AI_WIN
  DRAW
}

enum MovePlayer {
  HUMAN
  AI
}

// ─── Machine Learning ────────────────────────────────────────────────────────

model MLModel {
  id            String        @id @default(cuid())
  name          String
  description   String?
  algorithm     MLAlgorithm   @default(Q_LEARNING)
  qtable        Json          @default("{}")
  config        Json
  status        MLModelStatus @default(IDLE)
  totalEpisodes Int           @default(0)
  eloRating     Float         @default(1000)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions       TrainingSession[]
  checkpoints    MLCheckpoint[]
  benchmarks     MLBenchmarkResult[]
  eloHistory     MLEloHistory[]
  playerProfiles MLPlayerProfile[]

  @@map("ml_models")
}

model MLPlayerProfile {
  id                 String   @id @default(uuid())
  modelId            String
  userId             String
  gamesRecorded      Int      @default(0)
  movePatterns       Json     @default("{}")   // { stateKey: { cellIndex: count } }
  openingPreferences Json     @default("{}")   // { cellIndex: count } (first moves)
  tendencies         Json     @default("{}")   // { centerRate, cornerRate, blockingRate }
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, userId])
  @@map("ml_player_profiles")
}

model TrainingSession {
  id          String        @id @default(cuid())
  modelId     String
  mode        TrainingMode
  iterations  Int
  status      SessionStatus @default(PENDING)
  config      Json
  summary     Json?
  startedAt   DateTime      @default(now())
  completedAt DateTime?

  model    MLModel           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  episodes TrainingEpisode[]

  @@index([modelId])
  @@map("training_sessions")
}

model TrainingEpisode {
  id         String         @id @default(cuid())
  sessionId  String
  episodeNum Int
  outcome    EpisodeOutcome
  totalMoves Int
  avgQDelta  Float
  epsilon    Float
  durationMs Int

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("training_episodes")
}

model MLCheckpoint {
  id         String   @id @default(cuid())
  modelId    String
  episodeNum Int
  qtable     Json
  epsilon    Float
  eloRating  Float
  createdAt  DateTime @default(now())

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_checkpoints")
}

model MLBenchmarkResult {
  id       String   @id @default(cuid())
  modelId  String
  runAt    DateTime @default(now())
  vsRandom Json
  vsEasy   Json
  vsMedium Json
  vsHard   Json
  summary  Json

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_benchmark_results")
}

model MLEloHistory {
  id           String         @id @default(cuid())
  modelId      String
  eloRating    Float
  delta        Float
  opponentId   String?
  opponentType String
  outcome      EpisodeOutcome
  recordedAt   DateTime       @default(now())

  model MLModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("ml_elo_history")
}

model MLTournament {
  id           String    @id @default(cuid())
  status       String    @default("PENDING")
  modelIds     Json
  gamesPerPair Int       @default(50)
  results      Json      @default("{}")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("ml_tournaments")
}

enum MLAlgorithm {
  Q_LEARNING
  SARSA
  MONTE_CARLO
  POLICY_GRADIENT
  DQN
  ALPHA_ZERO
}

enum MLModelStatus {
  IDLE
  TRAINING
}

enum TrainingMode {
  SELF_PLAY
  VS_MINIMAX
  VS_HUMAN
}

enum SessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EpisodeOutcome {
  WIN
  LOSS
  DRAW
}
